# Copie para .env e preencha os valores.
# cp .env.example .env

MONGO_URI=mongodb://localhost:27017/petzara

JWT_SECRET=
REFRESH_SECRET=

# Porta da API (no macOS evite 5000 — é usada pelo AirPlay; use 5050 ou outra livre)
PORT=5050

# URLs da API e do frontend
BASE_URL=http://localhost:5050
CLIENT_URL=http://localhost:5173

# E-mail (Resend)
RESEND_API_KEY=
EMAIL_USER=

# Stripe — chaves em https://dashboard.stripe.com/apikeys
# Use sk_test_... em desenvolvimento
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Google Sign-In — deve ser o MESMO Client ID do frontend (VITE_GOOGLE_CLIENT_ID).
# Console: https://console.cloud.google.com/apis/credentials — tipo "ID do cliente da Web".
# Em "Origens JavaScript autorizadas" inclua: http://localhost:5173 e a URL de produção do app.
GOOGLE_CLIENT_ID=

# Opcional
NODE_ENV=development
SENTRY_DSN=
COOKIE_DOMAIN=
